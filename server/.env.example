# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Public-facing site URL — used in email templates and other absolute links
SITE_URL=https://dorkmugs.shop

# Comma-separated list of frontend origins allowed by CORS
# In dev this is the file:// origin or live-server URL
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://dorkmugs.shop,https://www.dorkmugs.shop

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite for dev (file path relative to /server)
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL for production — swap the line above with:
# DATABASE_URL="postgresql://user:pass@host:5432/dorkmugs?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_random_64_char_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Where to send customers after payment (append ?session_id={CHECKOUT_SESSION_ID})
STRIPE_SUCCESS_URL=https://dorkmugs.shop/order-success.html
STRIPE_CANCEL_URL=https://dorkmugs.shop/index.html

# ─── Printify ─────────────────────────────────────────────────────────────────
# Get from: https://printify.com/app/account/connections
PRINTIFY_API_KEY=
# Get from: Printify → Shops → copy the numeric ID from the URL
PRINTIFY_SHOP_ID=

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
# Use SendGrid, Postmark, or any SMTP provider
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_or_api_key
EMAIL_FROM=Dork Mugs <noreply@dorkmugs.shop>

# ─── Admin seed ───────────────────────────────────────────────────────────────
# Used only when running: npm run db:seed  (NEVER run in production with these defaults)
SEED_ADMIN_EMAIL=admin@dorkmugs.shop
SEED_ADMIN_PASSWORD=CHANGE_BEFORE_SEEDING
SEED_ADMIN_NAME=Admin
