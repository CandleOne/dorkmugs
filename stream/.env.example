# Stream environment variables
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
# YouTube Live stream key (from YouTube Studio → Go Live → Stream key)
YOUTUBE_KEY=your-youtube-stream-key-here

# Twitch stream key (from Twitch Dashboard → Settings → Stream → Primary Stream key)
TWITCH_KEY=your-twitch-stream-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Page to capture
TARGET_URL=https://your-website.com

# Video dimensions and framerate
WIDTH=1280
HEIGHT=720
FPS=10

# JPEG capture quality sent from Chrome (1-100)
JPEG_QUALITY=80

# H.264 CRF — lower = better quality, higher bitrate (18-51 range; 28 is a
# reasonable balance for live streaming)
CRF=28

# AAC audio bitrate
AUDIO_BITRATE=128k

# How long to wait after a crash before restarting (milliseconds)
RECONNECT_DELAY_MS=5000

# Page navigation timeout (milliseconds)
PAGE_TIMEOUT_MS=30000

# Absolute path to Chromium/Chrome binary (leave empty to use Puppeteer's bundled one)
# CHROMIUM_PATH=/usr/bin/chromium-browser

# Log file location (process must have write permission)
LOG_FILE=/var/log/webcam-stream.log
